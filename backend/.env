# Environment Variables for Joyful Creationz

# Admin Configuration
ADMIN_PASSWORD=joyful123

# WhatsApp Configuration (Meta Cloud API)
# Use your own WhatsApp Business phone number ID and permanent access token.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_DEFAULT_COUNTRY_CODE=27
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# Optional recipient for admin alerts
WHATSAPP_ADMIN_TO=27683079072

# Optional approved template name for ticket delivery outside the 24-hour window
WHATSAPP_TICKET_TEMPLATE_NAME=

# Server Configuration
PORT=3000
